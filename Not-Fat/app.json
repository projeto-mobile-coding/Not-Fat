{
  "expo": {
    "name": "Not-Fat",
    "slug": "Not-Fat",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./frontend/src/assets/images/splash-logo.png",
      "resizeMode": "native",
      "backgroundColor": "#ffffff",
      "plugins": [
        [
          "@react-native-google-signin/google-signin",
          {
            "iosUrlScheme": "com.googleusercontent.apps._some_id_here_"
          }
        ]
      ]
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.notfat.android",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {},
    "plugins": [
      "@react-native-google-signin/google-signin"
    ]
  }
}
